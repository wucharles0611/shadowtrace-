# ShadowTrace core environment variables (intro §4.7 + ISSUE-001 defaults)
# Copy to .env for local overrides. Defaults target Docker Compose service names.

# --- Application ---
APP_VERSION=0.1.0
APP_ENV=development

# --- Storage (P0 hard deps) ---
DATABASE_URL=postgresql+asyncpg://shadowtrace:shadowtrace@postgres:5432/shadowtrace
REDIS_URL=redis://redis:6379/0

# --- Source / ingestion ---
SOURCE_MODE=mock_xdr
SOURCE_READ_ONLY=true

# --- Tools ---
TOOL_MODE=mock

# --- Disposition / writeback ---
DISPOSITION_MODE=mock_xdr
DISPOSITION_ADAPTER_KIND=mock
DISPOSITION_BASE_URL=
DISPOSITION_CREDENTIAL_REF=
ALLOW_XDR_WRITEBACK=false
ALLOW_LIVE_SIDE_EFFECTS=false
WRITEBACK_FIELD_ALLOWLIST=status,disposition,comment
WRITEBACK_MAX_RETRIES=5
SIMULATION_ENABLED=true

# --- LLM ---
LLM_MODE=mock
LLM_API_BASE_URL=
LLM_API_KEY=
LLM_PRIMARY_MODEL=mock-model
LLM_FALLBACK_MODELS=
LLM_TIMEOUT_SECONDS=30

# --- Budget / guardrails (defaults; full wiring in later issues) ---
BUDGET_ENABLED=true
GLOBAL_TOKEN_BUDGET=1000000
EVENT_TOKEN_BUDGET=100000
EVENT_COST_BUDGET_USD=5.0
PER_AGENT_TOKEN_CAP=20000
QUALITY_JUDGE_ENABLED=false
GUARDRAIL_MODE=enforce
WM_STRICT=true

# --- Orchestration (later issues; safe defaults) ---
ORCHESTRATION_MODE=graph
REACT_ENABLED=false
TASK_MODE=background
CELERY_BROKER_URL=redis://redis:6379/1
APPROVAL_TIMEOUT_MINUTES=30
